{
  "name": "sekiro",
  "github_url": "https://github.com/AbijithBalaji/sekiro_grub_theme",
  "preview_image": "https://github.com/semimqmo/sekiro_grub_theme/raw/main/screenshot.png?raw=true",
  "description": "",
  "author": "Abijith Balaji",
  "version": "1.0",
  "steps": [
    {
      "type": "copy_dir",
      "from": "${MANIFEST_DIR}/sekiro",
      "to": "/boot/grub/themes/"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_THEME",
      "value": "/boot/grub/themes/sekiro/theme.txt"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TIMEOUT_STYLE",
      "value": "menu"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TERMINAL_OUTPUT",
      "value": "gfxterm"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_GFXPAYLOAD_LINUX",
      "value": "keep"
    }
  ]
}
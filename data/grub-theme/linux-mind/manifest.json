{
  "name": "linux-mind",
  "github_url": "https://www.pling.com/p/1397139/",
  "preview_image": "https://cdn.jsdelivr.net/gh/tealinuxos/tealinux-modularitea-libs@master/data/grub-theme/linux-mind/200.png",
  "description": "Linux Mind",
  "author": "corto44",
  "version": "1.0",
  "steps": [
    {
      "type": "copy_dir",
      "from": "${MANIFEST_DIR}/linux-mind",
      "to": "/boot/grub/themes/"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_THEME",
      "value": "/boot/grub/themes/linux-mind/theme.txt"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_DISTRIBUTOR",
      "value": "TeaLinuxOS"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TIMEOUT_STYLE",
      "value": "menu"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TERMINAL_INPUT",
      "value": "console"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_GFXMODE",
      "value": "1920x1080,auto"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_GFXPAYLOAD_LINUX",
      "value": "keep"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_CMDLINE_LINUX_DEFAULT",
      "value": "loglevel=3"
    }
  ]
}
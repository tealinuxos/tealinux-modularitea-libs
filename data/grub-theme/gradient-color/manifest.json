{
  "name": "gradient-color",
  "github_url": "https://github.com/MrVivekRajan/Grub-Themes",
  "preview_image": "",
  "description": "",
  "author": "MrVivekRajan",
  "version": "1.0",
  "steps": [
    {
      "type": "copy_dir",
      "from": "${MANIFEST_DIR}/gradient-color",
      "to": "/boot/grub/themes/"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_THEME",
      "value": "/boot/grub/themes/gradient-color/theme.txt"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TIMEOUT_STYLE",
      "value": "menu"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TERMINAL_OUTPUT",
      "value": "gfxterm"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_GFXPAYLOAD_LINUX",
      "value": "keep"
    }
  ]
}
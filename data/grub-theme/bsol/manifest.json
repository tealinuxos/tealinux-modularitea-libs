{
  "name": "bsol",
  "github_url": "https://github.com/harishnkr/bsol",
  "preview_image": "https://github.com/harishnkr/bsol/raw/main/.github/preview.png",
  "description": "Blue Screen of Life",
  "author": "harishnkr",
  "version": "1.0",
  "steps": [
    {
      "type": "copy_dir",
      "from": "${MANIFEST_DIR}/bsol",
      "to": "/boot/grub/themes/"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_THEME",
      "value": "/boot/grub/themes/bsol/theme.txt"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_DISTRIBUTOR",
      "value": "TeaLinuxOS"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TIMEOUT_STYLE",
      "value": "menu"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_TERMINAL_INPUT",
      "value": "console"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_GFXMODE",
      "value": "1920x1080,auto"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_GFXPAYLOAD_LINUX",
      "value": "keep"
    },
    {
      "type": "set_grub_var",
      "key": "GRUB_CMDLINE_LINUX_DEFAULT",
      "value": "loglevel=3"
    }
  ]
}